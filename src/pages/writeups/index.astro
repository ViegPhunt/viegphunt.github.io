---
import { getCollection } from 'astro:content';
import ListLayout from '@/layouts/ListLayout.astro';
import Image from '@/components/OptimizedImage.astro';

const allWriteups = await getCollection('writeups');
const writeupFolders = [...new Set(allWriteups.map((w) => w.slug.split("/")[0]))];

const writeupDirs = writeupFolders.map((folder) => {
	const writeup = allWriteups.find(w => w.slug.startsWith(folder));
	return {
		name: writeup?.data.title || folder,
		path: folder,
		banner: writeup?.data.banner,
		updated: writeup?.data.updated,
		description: writeup?.data.description,
		link: `/writeups/${folder}`,
	};
}).sort((a, b) => {
	if (!a.updated || !b.updated) return 0;
	return new Date(b.updated).getTime() - new Date(a.updated).getTime();
});
---

<ListLayout title="CTF Write-ups | ViegPhunt">
	<div class="w-full pb-[var(--section-stack)] article-grid">
		{writeupDirs.map((item) => (
			<a
				href={item.link}
				class="article-card"
			>
				{item.banner && (
					<div class="article-card__media">
						<Image 
							src={item.banner} 
							alt={item.name}
							width={640}
							height={360}
							class="article-card__image"
						/>
					</div>
				)}
				<div class="article-card__body">
					<div class="article-card__eyebrow">
						<span>Writeup</span>
					</div>
					<h3 class="article-card__title">{item.name}</h3>
					<p class="article-card__description">{item.description}</p>
					<div class="article-card__meta">
						{item.updated && (
							<div class="article-card__chip">
								<i class="fa-regular fa-calendar"></i>
								<span>{new Date(item.updated).toLocaleDateString('en-GB')}</span>
							</div>
						)}
						<div class="article-card__chip">
							<i class="fa-solid fa-hashtag"></i>
							<span>writeup</span>
						</div>
					</div>
					<span class="article-card__arrow">
						Read more <i class="fa-solid fa-arrow-right text-[0.7rem]"></i>
					</span>
				</div>
			</a>
		))}
	</div>
</ListLayout>
